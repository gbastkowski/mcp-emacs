{
  "name": "mcp-emacs-server",
  "version": "0.4.0",
  "description": "MCP server for Emacs integration",
  "type": "module",
  "main": "elisp/new-server/mcp-server.el",
  "bin": {
    "mcp-emacs": "bin/mcp-emacs-elisp",
    "mcp-emacs-node": "bin/mcp-emacs.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "node scripts/extract-elisp.js && tsc",
    "watch": "node scripts/extract-elisp.js && tsc --watch",
    "prepare": "npm run build",
    "test": "npm run build && node --test --test-concurrency 1 test/**/*.test.js"
  },
  "keywords": [
    "mcp",
    "emacs",
    "editor",
    "integration"
  ],
  "author": "Gunnar Bastkowski",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
